  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/y-a-v-a/Trumplang/issues"
  },
  "homepage": "https://github.com/y-a-v-a/Trumplang#readme",
  "dependencies": {
    "antlr4": "^4.8.0"
  },
  "devDependencies": {
    "antlr4-tool": "^1.1.1"
  }
