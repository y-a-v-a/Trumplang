{
  "name": "trumplang-website",
  "version": "1.0.0",
  "description": "The official website for Trumplang - THE MOST TREMENDOUS Programming Language",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --format=esm --platform=browser --keep-names --alias:fs=./src/stubs/empty.js --alias:path=./src/stubs/empty.js --outfile=public/playground.js",
    "start": "npm run build && serve public",
    "dev": "npm run build && serve public",
    "smoke": "npm run build && node test/smoke.mjs"
  },
  "keywords": [
    "trumplang",
    "website",
    "programming",
    "language"
  ],
  "dependencies": {
    "serve": "^14.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Vincent Bruijn <vebruijn@gmail.com>"
}
